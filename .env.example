# Facebook App credentials
FB_APP_ID=FB_APP_ID
FB_APP_SECRET=FB_APP_SECRET

# Webhook verify token
FB_WEBHOOK_VERIFY_TOKEN=tadaup_webhook_secret_2026

# OAuth redirect URI
FB_REDIRECT_URI=http://localhost:3458/auth/facebook/callback

# Frontend origin for CORS
FRONTEND_ORIGIN=http://localhost:3458

# ── MQTT — phải khớp với worker .env ─────────────────────────────────────────
MQTT_BROKER_URL=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# JWT secret — dùng để ký command, worker dùng để verify
# Phải khớp JWT_SECRET_KEY trong worker .env
JWT_SECRET_KEY=tadaup_local_jwt_secret_2026

# UUID của Worker — lấy từ log startup của worker: "Worker UUID: <uuid>"
# Sau khi chạy worker lần đầu, copy UUID vào đây
WORKER_UUID=dd01bbbb-bf88-4848-8d7e-eb1f199bf375

# Backend port
PORT=8082
